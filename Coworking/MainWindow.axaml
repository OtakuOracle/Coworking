<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Coworking.MainWindow"
        Title="Авторизация"
		Icon="Icon/icon.png">
	<StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
		<TextBox Name="EmailTextBox" Watermark="Логин" Margin="5" Width="200"></TextBox>
		<TextBox Name="PasswordTextBox" Watermark="Пароль" Margin="5" Width="200"></TextBox>
		<Button Content="Войти" Click="Auth_Click"  Margin="5" Width="200"/>
		<Button Content="Войти как гость" Click="Guest_Click"  Margin="5" Width="200"/>
	</StackPanel>
</Window>
