<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		x:CompileBindings="False"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Coworking.RoomWindow"
        Title="RoomWindow">

	<DockPanel>
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="5">
			<TextBox Watermark="Поиск" Width="200" Margin="5" Name="SearchBox" IsVisible="False" KeyUp="SearchBox_KeyUp"  FontFamily="Times New Roman"></TextBox>
			<ComboBox Margin="5" Width="200" Name="Sort"  IsVisible="False"  FontFamily="Times New Roman" SelectionChanged="Sort_SelectionChanged">
				<ComboBoxItem>По вместимости (возр.)</ComboBoxItem>
				<ComboBoxItem>По вместимости (убыв.)</ComboBoxItem>
				<ComboBoxItem>По стоимости (возр.)</ComboBoxItem>
				<ComboBoxItem>По стоимости (убыв.)</ComboBoxItem>
			</ComboBox>

			<ComboBox Margin="5" Width="200" Name="Filter" IsVisible="False" SelectionChanged="Filter_SelectionChanged" FontFamily="Times New Roman"></ComboBox>
			<TextBlock x:Name="FioTextBlock" Text="" FontFamily="Times New Roman"></TextBlock>
			<Image Source="Icon/logo.ico" Width="200" Height="200" HorizontalAlignment="Center"/>
		</StackPanel>

		<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center">
			<Button Content="Назад" Margin="5" Click="Back_Click"  FontFamily="Times New Roman"></Button>
			<Button Content="Добавить комнату" Margin="5" Name="AddButton" IsVisible="False" Click="AddButton_Click" Background="#FFA07A"  FontFamily="Times New Roman"></Button>
			<Button Content="Бронирования" Margin="5" Name="BookingButton" IsVisible="False" Click="BookingButton_Click" Background="#EE82EE"  FontFamily="Times New Roman"></Button>
		</StackPanel>

				
	<ListBox Name="RoomsBox" SelectionChanged="RoomsBox_SelectionChanged">
		<ListBox.ItemTemplate>
			<DataTemplate>
				<DockPanel>
				<StackPanel Orientation="Vertical" VerticalAlignment="Center" DockPanel.Dock="Left" Margin="5">
					<Image Source="{Binding GetPhoto}" Height="80" Width="80"></Image>
					</StackPanel>
			
				<StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5">
							<TextBlock Text="{Binding RoomName, StringFormat='Название:{0}'}" FontFamily="Times New Roman" Margin="5"/>
							<TextBlock Text="{Binding RoomType.RoomTypeName, StringFormat='Тип:{0}'}" FontFamily="Times New Roman" Margin="5"/>
							<TextBlock Text="{Binding Capacity, StringFormat='Вместимость:{0}'}" FontFamily="Times New Roman" Margin="5"/>
							<TextBlock Text="{Binding Cost, StringFormat='Цена:{0}'}" FontFamily="Times New Roman" Margin="5"/>
							<TextBlock Text="{Binding MinTime, StringFormat='Мин. время бронирования:{0}'}" FontFamily="Times New Roman" Margin="5"/>
							<TextBlock Text="{Binding Rating, StringFormat='Рейтинг:{0}'}" FontFamily="Times New Roman" Margin="5"/>
							<TextBlock Text="{Binding ColorRating}" FontFamily="Times New Roman"  Margin="5"/>
							<TextBlock Text="{Binding Discount, StringFormat='Скидка:{0}'}" Background="{Binding ColorDiscount}" FontFamily="Times New Roman" Margin="5"/>
							<TextBlock Text="{Binding Description, StringFormat='Описание:{0}'}" FontFamily="Times New Roman" Margin="5"/>
							<TextBlock Text="{Binding Cost, StringFormat='Цена:{0}'}" FontFamily="Times New Roman" Margin="5"/>
				 <TextBlock Text="Оборудование:" 
               FontFamily="Times New Roman"/>

					<ItemsControl ItemsSource="{Binding RoomEquipments}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>

								<TextBlock Text="{Binding Equipment.EquipmentName}" 
										   Margin="20,2,0,0" 
										   FontFamily="Times New Roman"/>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
					</StackPanel>
					</DockPanel>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</DockPanel>
</Window>
